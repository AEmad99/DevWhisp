{
  "project": {
    "name": "DevWhisp",
    "version": "0.2.0-plan",
    "description": "BridgeVoice-style small, tray-resident, push-to-talk voice-to-text desktop app with floating always-on-top pill widget. Embedded STT (Moonshine via ONNX Runtime), cursor-paste text injection, transcription history. CPU-only.",
    "owner": "Ahmed",
    "workspace": "D:\\projects\\DevWhisp",
    "license": "TBD",
    "created": "2026-06-26",
    "status": "planning"
  },
  "objectives": [
    "Tray-resident push-to-talk voice-to-text app",
    "Floating always-on-top pill widget with 5 states (idle/listening/processing/success/error)",
    "Embedded STT model (no cloud, no API key)",
    "CPU-only (works on machines without dedicated GPU)",
    "Cursor-paste text injection (clipboard + Ctrl/Cmd+V) into focused app",
    "Transcription history window (browse, search, copy, re-inject, delete)",
    "Custom dictionary (spoken phrase -> replacement)",
    "Onboarding wizard for first-run",
    "Sub-second first-token latency on 5s utterances",
    "Idle RAM <= 80 MB, bundle <= 25 MB",
    "Multilingual v2 (8+ languages)"
  ],
  "success_criteria": {
    "installer_size_mb_max": 25,
    "idle_ram_mb_max": 80,
    "cold_start_to_tray_ms_max": 800,
    "first_token_latency_ms_max": 300,
    "realtime_factor_min": 5,
    "wer_clean_english_max": 0.05,
    "cursor_paste_works_in": ["editor", "terminal", "browser_address_bar", "slack", "notion", "email", "code_ide"],
    "languages_v1": ["en"],
    "languages_v2": ["en", "zh", "ja", "ko", "es", "fr", "de", "pt"]
  },
  "ui_design": {
    "design_language": "Glassmorphism dark-mode first; soft purple/violet accent (#7C5CFF); Inter UI font; JetBrains Mono for transcripts; spring-ease-out animations 200-300ms",
    "brand_kit": {
      "family": ["DevTerm", "DevSpace", "DevWhisp"],
      "shared_dna": {
        "canvas": "1024x1024",
        "container": "rounded square 196-208px corner radius",
        "padding": "64-96px from edges",
        "accent_strategy": "white stroke + 1 solid fill element",
        "stroke_weight_px": "52-104",
        "naming_convention": "Dev + noun"
      },
      "color_palette": {
        "devterm": {"top": "#2a3350", "bottom": "#12131b", "accent": "#9bbcff -> #6a8dff", "vibe": "deep, terminal"},
        "devspace": {"top": "#7cc1ff", "bottom": "#4a90d9", "accent": "#ffffff", "vibe": "open, sky, AI"},
        "devwhisp": {"top": "#c4b5fd", "bottom": "#7c3aed", "accent": "#ffffff", "vibe": "soft, airy, violet"}
      },
      "icon_concepts": [
        {"id": "A", "name": "Wisp of Sound", "description": "Three nested wisp curves from a white node", "svg_path": "../design/devwhisp-icon-A-wisp.svg", "selected": false, "note": "superseded — organic wisps read as a feather/broom and broke the family's geometric language"},
        {"id": "B", "name": "W Monogram", "description": "Bold W letterform with two sound-wave wisps", "svg_path": "../design/devwhisp-icon-B-monogram.svg", "selected": false},
        {"id": "C", "name": "Breath", "description": "Single S-curve wisp from a tiny source dot", "svg_path": "../design/devwhisp-icon-C-breath.svg", "selected": false},
        {"id": "D", "name": "Sound Wisp", "description": "Sound wave that tapers into a wisp", "svg_path": "../design/devwhisp-icon-D-soundwisp.svg", "selected": false}
      ],
      "icon_final": {
        "name": "Voice Waves",
        "selected": true,
        "locked_at": "2026-06-26",
        "description": "Solid white source dot + three concentric arcs radiating right (opacity tapers 1.0 -> 0.80 -> 0.60). Geometric and family-matched with DevTerm (>_) and DevSpace (<*>): white strokes + one solid fill element, round caps, legible at 16px.",
        "canonical_svg": "../design/devwhisp-icon.svg",
        "raster_pipeline": "../design/render_voicewaves_icon.py",
        "in_app_components": ["src/lib/AppIcon.svelte", "src/lib/BrandMark.svelte"]
      },
      "pill_state_colors": {
        "idle": "#7C5CFF at 30% alpha (soft violet, brand color)",
        "listening": "#FF5C7C -> #FF9C5C gradient (red-pink, attention)",
        "processing": "#8A8FA3 (neutral gray, working)",
        "success": "#5CFF9C (mint green, positive)",
        "error": "#FFB45C (amber, warning)"
      },
      "typography": {
        "ui_font": "Inter",
        "transcript_in_pill": "JetBrains Mono",
        "transcript_in_history": "Inter"
      },
      "identifiers": {
        "app_name": "DevWhisp",
        "binary_name": "devwhisp",
        "tray_tooltip": "DevWhisp",
        "user_agent": "devwhisp/<version> (tauri)",
        "cargo_crate": "devwhisp"
      }
    },
    "windows": [
      {
        "name": "Pill widget",
        "type": "frameless_transparent_always_on_top",
        "default_position": "bottom-center, 24px from edge",
        "states": [
          {"id": "idle", "size": "120x40", "elements": ["mic_icon_dim", "hover_label_optional"], "interaction": ["hover_show_label", "double_click_toggle", "drag_to_reposition", "right_click_menu"]},
          {"id": "listening", "size": "280x56", "elements": ["mic_icon_solid", "7_band_audio_visualizer", "partial_transcript_text"], "animation": "200ms spring expand"},
          {"id": "processing", "size": "280x56", "elements": ["loading_spinner", "transcribing_label", "elapsed_ms"], "animation": "morph from listening"},
          {"id": "success", "size": "160x40", "elements": ["green_check", "pasted_label"], "duration": "600ms then auto-collapse"},
          {"id": "error", "size": "320x56", "elements": ["error_icon", "error_message"], "duration": "3000ms then auto-collapse"}
        ],
        "behaviors": ["drag_to_reposition", "snap_to_edge_80px", "click_through_in_idle_optional", "auto_hide_after_5s_optional", "multi_monitor_latch_to_primary"]
      },
      {
        "name": "Tray icon + menu",
        "tray_icon": "circular mic badge, dark bg, accent color, pulses while recording",
        "menu": [
          {"label": "Start/Stop Recording", "dynamic": true},
          {"label": "{hotkey} · {mode}", "dynamic": true, "disabled": true},
          {"label": "{model} · {language}", "dynamic": true, "disabled": true},
          {"separator": true},
          {"label": "Open History"},
          {"label": "Settings..."},
          {"label": "Help"},
          {"separator": true},
          {"label": "Launch on startup", "type": "checkbox"},
          {"label": "Quit DevWhisp"}
        ]
      },
      {
        "name": "History window",
        "type": "normal_window",
        "size": "720x640",
        "sections": ["header_search_filter", "transcript_list", "footer_stats"],
        "row_metadata": ["timestamp", "duration", "word_count", "source_badge", "text_snippet", "copy_button"],
        "row_actions": ["hover_copy", "hover_delete", "click_expand", "right_click_context"],
        "context_actions": ["copy", "re-inject", "delete", "add_to_dictionary"],
        "footer_stats": ["today_count", "today_words", "today_wpm", "settings_link"]
      },
      {
        "name": "Settings panel",
        "type": "modal",
        "size": "640x720",
        "layout": "sidebar_nav + content",
        "sections": [
          {"id": "general", "items": ["launch_on_startup", "minimize_to_tray", "ui_language"]},
          {"id": "models", "items": ["model_picker", "download_manager", "size_accuracy_metadata"]},
          {"id": "theme", "items": ["dark_light_system", "accent_color"]},
          {"id": "language", "items": ["ui_language", "stt_language"]},
          {"id": "audio", "items": ["input_device", "noise_suppression", "gain"]},
          {"id": "shortcuts", "items": ["record_hotkey", "open_history", "open_settings"]},
          {"id": "history", "items": ["clear_all", "export", "retention_days"]},
          {"id": "notifications", "items": ["toast_on_complete", "completion_sound", "badge"]},
          {"id": "updates", "items": ["auto_update_channel"]},
          {"id": "about", "items": ["version", "links", "check_for_updates"]}
        ]
      },
      {
        "name": "Onboarding wizard",
        "type": "first_run_only",
        "steps": [
          {"step": 1, "title": "Welcome", "content": "Talk instead of type. Value prop + screenshot"},
          {"step": 2, "title": "Permissions", "content": "Microphone + accessibility permission requests"},
          {"step": 3, "title": "Pick a model", "content": "Moonshine Tiny (50MB) recommended; Base (100MB) more accurate"},
          {"step": 4, "title": "Set hotkey", "content": "Capture keybind, default Ctrl+Shift+Space"},
          {"step": 5, "title": "Try it", "content": "Live test - must succeed to complete onboarding"}
        ]
      }
    ]
  },
  "cursor_paste_injection": {
    "algorithm": [
      "1. Before recording: save currently-focused window handle + clipboard snapshot",
      "2. On transcription complete: format text (capitalize, dict replace, append space)",
      "3. clipboard.set(formatted_text) via arboard",
      "4. Wait 30ms for clipboard propagation",
      "5. Send synthetic Ctrl+V (Win/Linux) or Cmd+V (macOS) via enigo",
      "6. After 5s: restore original clipboard content"
    ],
    "edge_cases": {
      "no_focused_text_field": "Show notification + keep text on clipboard",
      "terminal_bracketed_paste": "Wrap in \\x1b[200~\\x1b[201~",
      "url_field": "Skip auto-capitalize",
      "rich_text_editor": "Plain text clipboard fallback",
      "fullscreen_blocker": "Fall back to clipboard-only + notification"
    },
    "formatting_options": {
      "auto_capitalize": "configurable",
      "append_space": "configurable",
      "dictionary_replacements": "applied longest-match-first, case-insensitive",
      "strip_whitespace": "leading + trailing"
    }
  },
  "architecture": {
    "selected": "A",
    "options_evaluated": ["A_Tauri_Rust_Moonshine", "B_Electron_WhisperCPP", "C_Native_Rust_DIY"],
    "selected_rationale": "Smallest bundle (5-15 MB), lowest RAM (30-60 MB), native Rust FFI to ONNX Runtime avoids Node.js boundary. Moonshine is the best 2025-2026 fit for short-utterance, CPU-only, edge STT. UI designs are stack-agnostic so B is a viable fallback if Rust ramp-up is a blocker.",
    "stack": {
      "framework": "Tauri 2.x",
      "backend_language": "Rust 1.80+",
      "frontend_language": "TypeScript 5.x",
      "frontend_framework": "Svelte 5 (preferred) or React 18",
      "stt_engine": "Moonshine via ONNX Runtime (ort crate)",
      "stt_models": [
        "moonshine-tiny-en (~50MB INT8) - v1 default",
        "moonshine-base-en (~100MB INT8) - v1 high-accuracy option",
        "moonshine-medium-multilingual (~350MB INT8) - v2",
        "whisper.cpp small (~466MB) - v1 fallback",
        "vosk small (~50MB per language) - v2 low-end fallback"
      ],
      "audio": "cpal + rubato + silero-vad + FFT visualizer",
      "desktop_integration": [
        "tauri-plugin-global-shortcut",
        "tauri-plugin-system-tray",
        "tauri-plugin-autostart",
        "tauri-plugin-single-instance",
        "tauri-plugin-updater",
        "tauri-plugin-clipboard-manager",
        "tauri-plugin-store"
      ],
      "text_injection": "enigo + arboard with clipboard save/restore",
      "storage": "rusqlite (transcription history) + tauri-plugin-store (settings)",
      "ci_cd": "GitHub Actions + tauri-action",
      "distribution": ["MSI/NSIS (Windows)", "DMG (macOS)", "DEB/AppImage (Linux)"]
    }
  },
  "milestones": [
    {"id": "M1", "name": "Feasibility spike", "duration_weeks": 1, "exit_criterion": "End-to-end mic -> Moonshine -> cursor-paste on Windows; latency/RAM/RTF measured; first pill render"},
    {"id": "M2", "name": "Core engine", "duration_weeks": 3, "exit_criterion": "Push-to-talk works on 3 Windows machines; text pasted into any focused app; history saved; dictionary works"},
    {"id": "M3", "name": "UI/UX", "duration_weeks": 2, "exit_criterion": "Pill widget + history window + settings panel + onboarding all working; first-time-to-paste < 2 min"},
    {"id": "M4", "name": "Hardening & release", "duration_weeks": 2, "exit_criterion": "Signed v0.1.0 installer; CI green; auto-update working; theme + a11y done"},
    {"id": "M5", "name": "Multilingual + cross-platform", "duration_weeks": 3, "exit_criterion": "v1.0.0 with multilingual support, macOS + Linux ports, export, wake word"}
  ],
